# Google Cloud Vision API
# Option 1: Service account key file path (local development)
GOOGLE_APPLICATION_CREDENTIALS=./service-account-key.json

# Option 2: Base64-encoded service account key (Vercel deployment)
# GOOGLE_CREDENTIALS_BASE64=base64_encoded_service_account_json

# Google Cloud Project ID
GOOGLE_CLOUD_PROJECT=your-gcp-project-id

# AWS Bedrock
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key

# Database（ローカル: docker-compose / 本番: Aurora PostgreSQL）
DATABASE_URL=postgresql://fridge:fridge_local_pw@localhost:5432/fridge_ai

# NextAuth (Auth.js)
NEXTAUTH_URL=http://localhost:3000
# 生成: openssl rand -base64 32
NEXTAUTH_SECRET=your-nextauth-secret

# Google OAuth（Google Cloud Console で取得）
GOOGLE_CLIENT_ID=your-google-oauth-client-id
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret
